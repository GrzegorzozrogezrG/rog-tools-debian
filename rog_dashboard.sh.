#!/bin/bash

# Pobieranie aktualnych danych
current_temp=$(cat /sys/class/thermal/thermal_zone0/temp)
temp_c=$((current_temp/1000))
current_profile=$(asusctl profile get | cut -d':' -f2)

# Menu główne Zenity
choice=$(zenity --list --title="ROG Control Panel" --width=400 --height=450 \
    --text="Status: $temp_c°C | Profil: $current_profile\n\nWybierz akcję:" \
    --column="Opcja" --column="Opis" \
    "1. Ustaw profil Turbo" "Maksymalna wydajność i chłodzenie" \
    "2. Ustaw profil Balanced" "Standardowa praca (bez mrugania)" \
    "3. Ustaw profil Quiet" "Cisza (może mrugać monitorem)" \
    "4. Włącz Strażnika (Skrypt)" "Uruchamia automatyczne chłodzenie" \
    "5. Limit baterii 80%" "Chroni żywotność ogniwa" \
    "6. Wyłącz Strażnika" "Zabija proces w tle")

# Obsługa wyborów
case $choice in
    "1. Ustaw profil Turbo") asusctl profile set Turbo ;;
    "2. Ustaw profil Balanced") asusctl profile set Balanced ;;
    "3. Ustaw profil Quiet") asusctl profile set Quiet ;;
    "4. Włącz Strażnika (Skrypt)") 
        nohup ~/rog_guardian.sh > /dev/null 2>&1 & 
        zenity --info --text="Strażnik uruchomiony w tle." ;;
    "5. Limit baterii 80%") asusctl battery-policy 80 ;;
    "6. Wyłącz Strażnika") 
        pkill -f rog_guardian.sh
        zenity --info --text="Strażnik został wyłączony." ;;
esac
